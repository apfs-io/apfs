{
  "version": "2",
  "description": "Image processing workflow — preview, base64 thumbnail, original retention",
  "content_types": ["image/*"],
  "on": {
    "upload": {}
  },
  "jobs": {
    "preview": {
      "runs_on": ["image-worker"],
      "steps": [
        {
          "name": "Resize to preview width",
          "uses": "procedure",
          "with": {
            "name": "image-resize-w",
            "width": 200,
            "target": "preview.jpg"
          }
        }
      ]
    },
    "base64_thumb": {
      "runs_on": ["image-worker"],
      "steps": [
        {
          "name": "Extract dominant colors",
          "uses": "image",
          "with": {
            "action": "extract-colors",
            "count": 7,
            "target": "base64thumb"
          }
        }
      ]
    },
    "strip_meta": {
      "needs": ["preview"],
      "runs_on": ["image-worker"],
      "steps": [
        {
          "name": "Strip EXIF metadata",
          "uses": "procedure",
          "with": {
            "name": "image-strip-meta",
            "target": "preview.jpg"
          }
        }
      ]
    }
  }
}
